{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://raw.githubusercontent.com/pipelabs/pd4castr-model-examples/main/schemas/v1/model-config.json",
  "title": "pd4castr model configuration schema",
  "description": "Schema for .pd4castrrc.json configuration files",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "forecastVariable", "timeHorizon", "inputs", "outputs"],
  "properties": {
    "$$id": {
      "type": ["null", "string"],
      "default": null,
      "description": "DO NOT EDIT: Unique ID for the model."
    },
    "$$modelGroupID": {
      "type": ["null", "string"],
      "default": null,
      "description": "DO NOT EDIT: Unique ID of the group the model belongs to."
    },
    "$$revision": {
      "type": ["null", "integer"],
      "minimum": 0,
      "default": null,
      "description": "DO NOT EDIT: Revision of the model."
    },
    "$$dockerImage": {
      "type": ["null", "string"],
      "default": null,
      "description": "DO NOT EDIT: Docker image name. Initially null until published, then populated with the image name."
    },
    "$$configVersion": {
      "type": "integer",
      "minimum": 0,
      "default": 0,
      "description": "DO NOT EDIT: Configuration version number."
    },
    "name": {
      "type": "string",
      "description": "Name of the model."
    },
    "metadata": {
      "type": "object",
      "description": "Flexible object for storing model metadata. Can contain any properties.",
      "additionalProperties": true
    },
    "forecastVariable": {
      "type": "string",
      "enum": ["price"],
      "description": "The type of forecast variable in the model output."
    },
    "timeHorizon": {
      "type": "string",
      "enum": ["day_ahead", "week_ahead", "quarterly", "historical"],
      "description": "The time horizon of the forecast."
    },
    "displayTimezone": {
      "type": "string",
      "default": "Australia/Brisbane",
      "description": "IANA time zone used for displaying model data."
    },
    "public": {
      "type": "boolean",
      "default": false,
      "description": "Whether the model is publicly accessible."
    },
    "runDatetimeQuery": {
      "type": ["null", "string"],
      "default": null,
      "description": "Path to SQL query for determining the model run datetime."
    },
    "inputs": {
      "type": "array",
      "description": "Array of model inputs with optional data fetchers.",
      "items": {
        "type": "object",
        "required": ["key", "trigger"],
        "additionalProperties": false,
        "properties": {
          "key": {
            "type": "string",
            "description": "Unique key for referencing this input."
          },
          "inputSource": {
            "type": "string",
            "description": "Identifier for the input data source."
          },
          "trigger": {
            "type": "string",
            "enum": ["WAIT_FOR_LATEST_FILE", "USE_MOST_RECENT_FILE"],
            "description": "Condition that determines when this input is ready to be used to trigger a model run."
          },
          "uploadFileFormat": {
            "type": "string",
            "enum": ["json", "csv", "parquet"],
            "default": "json",
            "description": "Format of the input file that will be uploaded to the input source."
          },
          "targetFileFormat": {
            "type": "string",
            "enum": ["json", "csv", "parquet"],
            "default": "json",
            "description": "Format of the input file that will be used in the model. Uploaded files will be converted to this format."
          },
          "fetcher": {
            "type": "object",
            "required": ["type", "checkInterval", "config"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["AEMO_MMS"],
                "description": "Type of data fetcher."
              },
              "checkInterval": {
                "type": "integer",
                "minimum": 60,
                "description": "Interval in seconds to check for new data."
              },
              "config": {
                "type": "object",
                "required": ["checkQuery", "fetchQuery"],
                "additionalProperties": false,
                "properties": {
                  "checkQuery": {
                    "type": "string",
                    "description": "Path to SQL query for checking if we need to fetch new data."
                  },
                  "fetchQuery": {
                    "type": "string",
                    "description": "Path to SQL query for fetching data."
                  }
                }
              }
            }
          }
        }
      }
    },
    "inputAggregations": {
      "type": "array",
      "default": [],
      "description": "Array of input aggregation definitions.",
      "items": {
        "type": "object",
        "required": ["name", "query"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the input aggregation."
          },
          "query": {
            "type": "string",
            "description": "Path to SQL query for the aggregation."
          },
          "description": {
            "type": "string",
            "default": "",
            "description": "Description of the input aggregation."
          },
          "colours": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "description": "Array of colour values for the aggregation."
          }
        }
      }
    },
    "outputs": {
      "type": "array",
      "description": "Array of model output variables.",
      "items": {
        "type": "object",
        "required": ["name", "key", "type", "seriesKey"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the output variable."
          },
          "key": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$",
            "description": "Unique key for referencing this output. Lowercase alphanumeric with hyphens and underscores."
          },
          "type": {
            "type": "string",
            "enum": [
              "float",
              "integer",
              "string",
              "date",
              "boolean",
              "unknown"
            ],
            "description": "Type of the output variable."
          },
          "seriesKey": {
            "type": "boolean",
            "description": "Whether this output is a series key."
          },
          "colour": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$",
            "description": "Hex color code that will be used to display this output."
          }
        }
      }
    },
    "sensitivities": {
      "type": "array",
      "default": [],
      "description": "Array of sensitivity analysis definitions.",
      "items": {
        "type": "object",
        "required": ["name", "key", "query"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the sensitivity."
          },
          "key": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9_-]*$",
            "description": "Unique key for referencing this sensitivity. Lowercase alphanumeric with hyphens and underscores."
          },
          "query": {
            "type": "string",
            "description": "Path to SQL query for the sensitivity."
          }
        }
      }
    }
  }
}
